{
  "name": "utility-template",
  "private": true,
  "version": "1.17.0",
  "type": "module",
  "scripts": {
    "dev:api": "tsx watch --include \"src/api/procedures.ts\" --ignore \"generated/**\" src/api/server.ts 2>&1 | tee -a api-dev.log",
    "dev:migrations": "dotenv -e .env.development -- prisma migrate dev --name auto --skip-generate 2>&1 | tee -a api-dev.log",
    "dev:free-port": "lsof -ti :$PORT | xargs -r kill -9 2>/dev/null || true",
    "dev:types": "dts-bundle-generator --out-file=dev-api-exports.d.ts --no-check --project tsconfig.json --external-inlines @babel/types -- src/api/procedures.ts",
    "dev": "dotenv -e .env.development -- run-s dev:free-port dev:migrations dev:api",
    "check": "run-p check:types check:config",
    "check:types": "tsc --noEmit",
    "check:config": "tsx app.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "postinstall": "prisma generate"
  },
  "peerDependencies": {
    "@trpc/client": "^10.11.0",
    "@trpc/server": "^10.11.0",
    "openai": "~4.42.0"
  },
  "dependencies": {
    "@adaptive-ai/sdk": "0.1.37",
    "@hono/node-server": "^1.19.13",
    "@prisma/adapter-better-sqlite3": "^6.18.0",
    "@prisma/client": "^6.7.0",
    "discord.js": "^14.26.3",
    "dotenv": "^17.2.3",
    "hono": "^4.12.12",
    "nodemon": "^3.1.11",
    "npm-run-all2": "^8.0.4",
    "superjson": "^2.2.2",
    "typed-rpc": "^6.1.1",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.0.14",
    "dotenv-cli": "^11.0.0",
    "dts-bundle-generator": "^9.5.1",
    "eslint": "^9.30.1",
    "prettier": "3.6.2",
    "prisma": "^6.7.0",
    "tsx": "^4.20.6",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.56.0"
  },
  "overrides": {
    "effect": "^3.21.0",
    "minimatch": "^10.2.4"
  }
}
